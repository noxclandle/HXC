generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(uuid()) @db.Uuid
  email             String?         @unique
  password          String?
  name              String?
  handle_name       String?
  alias_name        String?
  photo_url         String?
  is_alias_active   Boolean         @default(false)
  is_alias_unlocked Boolean         @default(false)
  address           String?
  phone             String?
  role              String          @default("member")
  rank              String          @default("Member")
  link_x            String?
  link_instagram    String?
  link_website      String?
  rt_balance        Int             @default(0)
  last_daily_at     DateTime?
  ai_config         Json?
  owned_assets      Json?
  unlocked_titles   Json?
  created_at        DateTime        @default(now())
  equipped_assets   Json?
  logo_url          String?
  link_facebook     String?
  link_line        String?
  exp              Int             @default(0)
  last_read_news_at DateTime?
  // 外部ドキュメント・資料リンク集 (JSON: [{title: string, url: string}])
  portfolio_links   Json?           @default("[]")
  reset_token       String?         @unique
  reset_token_at    DateTime?
  audit_logs        AuditLog[]
  card              Card?
  chat_messages     ChatMessage[]
  contacts          Contact[]       @relation("UserContacts")
  device_bindings   DeviceBinding[]
  rt_transactions   RTTransaction[]
  card_messages     CardMessage[]   @relation("ReceivedMessages")

  @@map("users")
}

model CardMessage {
  id               String   @id @default(uuid()) @db.Uuid
  target_user_id   String   @db.Uuid
  sender_name      String
  sender_company   String?
  content          String
  is_read          Boolean  @default(false)
  created_at       DateTime @default(now())
  target_user      User     @relation("ReceivedMessages", fields: [target_user_id], references: [id])

  @@map("card_messages")
}

model DeviceBinding {
  id           String   @id @default(uuid()) @db.Uuid
  user_id      String   @db.Uuid
  device_token String   @unique
  user_agent   String?
  created_at   DateTime @default(now())
  last_used_at DateTime @default(now())
  user         User     @relation(fields: [user_id], references: [id])

  @@map("device_bindings")
}

model ChatMessage {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  role       String
  text       String
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@map("chat_messages")
}

model Contact {
  id          String   @id @default(uuid()) @db.Uuid
  owner_id    String   @db.Uuid
  name        String
  handle_name String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  ai_tags     Json?
  coord_x     Float?
  coord_y     Float?
  created_at  DateTime @default(now())
  owner       User     @relation("UserContacts", fields: [owner_id], references: [id])

  @@map("contacts")
}

model Card {
  uid              String    @id
  internal_serial  String    @unique
  status           String    @default("unissued")
  user_id          String?   @unique @db.Uuid
  issued_at        DateTime?
  activated_at     DateTime?
  activation_token String?   @unique
  token_expires_at DateTime?
  user             User?     @relation(fields: [user_id], references: [id])
  order            Order?

  @@map("cards")
}

model RTTransaction {
  id          Int      @id @default(autoincrement())
  user_id     String   @db.Uuid
  amount      Int
  type        String
  description String?
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])

  @@map("rt_transactions")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String?  @db.Uuid
  action     String
  details    Json?
  ip_address String?
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}

model ScheduledTask {
  id           String    @id @default(uuid()) @db.Uuid
  action       String
  payload      Json
  scheduled_at DateTime
  executed_at  DateTime?
  status       String    @default("pending")
  created_at   DateTime  @default(now())

  @@map("scheduled_tasks")
}

model SystemConfig {
  key        String   @id
  value      Json
  updated_at DateTime @updatedAt

  @@map("system_configs")
}

model Report {
  id             String   @id @default(uuid()) @db.Uuid
  reporter_id    String?  @db.Uuid
  target_user_id String   @db.Uuid
  reason         String
  details        String?
  status         String   @default("pending")
  created_at     DateTime @default(now())

  @@map("reports")
}

model Announcement {
  id           String   @id @default(uuid()) @db.Uuid
  title        String
  content      String
  type         String   @default("update")
  is_published Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("announcements")
}

model Inquiry {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  email      String
  subject    String?
  message    String
  status     String   @default("pending")
  replies    Json?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("inquiries")
}

model Order {
  id                String    @id @default(uuid()) @db.Uuid
  stripe_session_id String?   @unique
  tier              String
  variant           String?
  price             Int
  customer_email    String
  customer_name     String
  shipping_address  Json?
  status            String    @default("paid")
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  card_uid          String?   @unique
  shipped_at        DateTime?
  card              Card?     @relation(fields: [card_uid], references: [uid])

  @@map("orders")
}

model ResonanceLink {
  id           String   @id @default(uuid()) @db.Uuid
  requester_id String   @db.Uuid
  target_id    String   @db.Uuid
  status       String   @default("pending") // "pending", "connected"
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([requester_id, target_id])
  @@map("resonance_links")
}
